            document.getElementById('planningContainer').style.top = document.getElementById('gridY').value + 'px';
            document.getElementById('rulesSection').style.left = document.getElementById('rulesX').value + 'px';
            document.getElementById('rulesSection').style.top = document.getElementById('rulesY').value + 'px';
            document.getElementById('rulesSection').style.width = document.getElementById('rulesWidth').value + 'px';
        }
        document.getElementById('rulesSection').style.display = document.getElementById('rulesVisible').checked ? 'block' : 'none';
    }

    // Synchroniser les sliders avec les positions réelles des éléments (après drag ou au démarrage)
    function syncSlidersFromDOM() {
        const logoRect = document.getElementById('logoArea').getBoundingClientRect();
        const titleRect = document.getElementById('titleInfo').getBoundingClientRect();
        const adminRect = document.getElementById('adminSelector').getBoundingClientRect();
        const buttonsRect = document.getElementById('controlsBlock').getBoundingClientRect();
        const gridRect = document.getElementById('planningContainer').getBoundingClientRect();
        const rulesRect = document.getElementById('rulesSection').getBoundingClientRect();
        const containerRect = container.getBoundingClientRect();
        document.getElementById('logoX').value = Math.round(logoRect.left - containerRect.left);
        document.getElementById('logoY').value = Math.round(logoRect.top - containerRect.top);
        document.getElementById('titleX').value = Math.round(titleRect.left - containerRect.left);
        document.getElementById('titleY').value = Math.round(titleRect.top - containerRect.top);
        document.getElementById('adminX').value = Math.round(adminRect.left - containerRect.left);
        document.getElementById('adminY').value = Math.round(adminRect.top - containerRect.top);
        document.getElementById('buttonsY').value = Math.round(buttonsRect.top - containerRect.top);
        document.getElementById('gridX').value = Math.round(gridRect.left - containerRect.left);
        document.getElementById('gridY').value = Math.round(gridRect.top - containerRect.top);
        document.getElementById('rulesX').value = Math.round(rulesRect.left - containerRect.left);
        document.getElementById('rulesY').value = Math.round(rulesRect.top - containerRect.top);
        document.getElementById('rulesWidth').value = rulesRect.width;
        // Récupérer les valeurs actuelles des CSS pour initialiser les autres champs
        document.getElementById('logoSize').value = parseInt(getComputedStyle(document.documentElement).getPropertyValue('--logo-width')) || 70;
        document.getElementById('titleSize').value = parseInt(getComputedStyle(document.documentElement).getPropertyValue('--title-size')) || 28;
        document.getElementById('logoVisible').checked = getComputedStyle(document.documentElement).getPropertyValue('--logo-visible').trim() !== 'none';
        document.getElementById('titleVisible').checked = getComputedStyle(document.documentElement).getPropertyValue('--title-visible').trim() !== 'none';
        document.getElementById('adminVisible').checked = getComputedStyle(document.documentElement).getPropertyValue('--admin-visible').trim() !== 'none';
        document.getElementById('buttonsVisible').checked = getComputedStyle(document.documentElement).getPropertyValue('--buttons-visible').trim() !== 'none';
        document.getElementById('rulesVisible').checked = getComputedStyle(document.documentElement).getPropertyValue('--rules-visible').trim() !== 'none';
        // Couleurs
        document.getElementById('bgColor').value = getComputedStyle(document.documentElement).getPropertyValue('--bg-color').trim() || '#f0f2f5';
        document.getElementById('logoBg').value = getComputedStyle(document.documentElement).getPropertyValue('--logo-bg').trim() || '#e0e0e0';
        document.getElementById('logoColor').value = getComputedStyle(document.documentElement).getPropertyValue('--logo-color').trim() || '#333';
        document.getElementById('titleColor').value = getComputedStyle(document.documentElement).getPropertyValue('--title-color').trim() || '#1a1a1e';
        document.getElementById('adminBg').value = getComputedStyle(document.documentElement).getPropertyValue('--admin-bg').trim() || '#f0f0f0';
        document.getElementById('adminText').value = getComputedStyle(document.documentElement).getPropertyValue('--admin-text').trim() || '#333';
        document.getElementById('gridBg').value = getComputedStyle(document.documentElement).getPropertyValue('--grid-bg').trim() || 'rgba(255,255,255,0.7)';
        document.getElementById('gridBorder').value = getComputedStyle(document.documentElement).getPropertyValue('--grid-border').trim() || '#ccc';
        document.getElementById('gridText').value = getComputedStyle(document.documentElement).getPropertyValue('--grid-text').trim() || '#1a1a1e';
        document.getElementById('rulesBg').value = getComputedStyle(document.documentElement).getPropertyValue('--rules-bg').trim() || '#fafafa';
        document.getElementById('rulesBorder').value = getComputedStyle(document.documentElement).getPropertyValue('--rules-border').trim() || '#ddd';
        document.getElementById('rulesText').value = getComputedStyle(document.documentElement).getPropertyValue('--rules-text').trim() || '#333';
        applyAllStyles();
    }

    // Drag & drop pour chaque élément
    function makeDraggable(elementId, xId, yId) {
        const el = document.getElementById(elementId);
        if(!el) return;
        let isDragging = false, startX, startY, startLeft, startTop;
        el.addEventListener('mousedown', (e) => {
            if(!isConfigMode) return;
            e.preventDefault();
            isDragging = true;
            startX = e.clientX;
            startY = e.clientY;
            const rect = el.getBoundingClientRect();
            const parentRect = container.getBoundingClientRect();
            startLeft = rect.left - parentRect.left;
            startTop = rect.top - parentRect.top;
            el.style.cursor = 'grabbing';
        });
        window.addEventListener('mousemove', (e) => {
            if(!isDragging) return;
            const dx = e.clientX - startX;
            const dy = e.clientY - startY;
            let newLeft = startLeft + dx;
            let newTop = startTop + dy;
            if(xId) document.getElementById(xId).value = newLeft;
            if(yId) document.getElementById(yId).value = newTop;
            applyAllStyles();
        });
        window.addEventListener('mouseup', () => { isDragging = false; if(el) el.style.cursor = ''; });
    }

    function initConfigMode() {
        makeDraggable('logoArea', 'logoX', 'logoY');
        makeDraggable('titleInfo', 'titleX', 'titleY');
        makeDraggable('adminSelector', 'adminX', 'adminY');
        makeDraggable('controlsBlock', null, 'buttonsY');
        // Écouter tous les changements de contrôles
        const allInputs = ['logoX','logoY','logoSize','titleX','titleY','titleSize','adminX','adminY','buttonsY','gridX','gridY','rulesX','rulesY','rulesWidth',
                           'bgColor','logoBg','logoColor','titleColor','adminBg','adminText','gridBg','gridBorder','gridText','rulesBg','rulesBorder','rulesText'];
        allInputs.forEach(id => {
            const el = document.getElementById(id);
            if(el) el.addEventListener('input', applyAllStyles);
        });
        const checkboxes = ['logoVisible','titleVisible','adminVisible','buttonsVisible','rulesVisible'];
        checkboxes.forEach(id => {
            const cb = document.getElementById(id);
            if(cb) cb.addEventListener('change', applyAllStyles);
        });
        document.getElementById('applyBgBtn').addEventListener('click', () => {
            let url = document.getElementById('bgImageUrl').value.trim();
            if(url) document.documentElement.style.setProperty('--bg-image', `url('${url}')`);
            else document.documentElement.style.setProperty('--bg-image', 'none');
        });
        applyAllStyles();
    }

    toggleBtn.addEventListener('click', () => {
        isConfigMode = !isConfigMode;
        if(isConfigMode) {
            container.classList.add('config-mode');
            configPanel.classList.add('active');
            syncSlidersFromDOM();
        } else {
            container.classList.remove('config-mode');
            configPanel.classList.remove('active');
        }
    });
    document.getElementById('closeConfigBtn').addEventListener('click', () => {
        isConfigMode = false;
        container.classList.remove('config-mode');
        configPanel.classList.remove('active');
    });
    document.getElementById('copyCssBtn').addEventListener('click', () => {
