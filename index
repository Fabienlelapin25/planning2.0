        document.documentElement.style.setProperty('--admin-visible', document.getElementById('adminVisible').checked ? 'flex' : 'none');
        document.documentElement.style.setProperty('--admin-bg', document.getElementById('adminBg').value);
        document.documentElement.style.setProperty('--admin-text', document.getElementById('adminText').value);
        
        // Boutons
        document.documentElement.style.setProperty('--buttons-top', document.getElementById('buttonsY').value + 'px');
