        // Appliquer les positions absolues en mode config
        if(isConfigMode) {
            document.getElementById('logoArea').style.left = document.getElementById('logoX').value + 'px';
            document.getElementById('logoArea').style.top = document.getElementById('logoY').value + 'px';
            document.getElementById('titleInfo').style.left = document.getElementById('titleX').value + 'px';
            document.getElementById('titleInfo').style.top = document.getElementById('titleY').value + 'px';
