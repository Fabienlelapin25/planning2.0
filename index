        navigator.clipboard.writeText(css).then(() => showToast('CSS copié !'));
    });

    // Initialisation globale
    function init() {
        initDates();
        generateGrid();
        loadFromLocalStorage();
        setupBaseEvents();
        initConfigMode();
        setTimeout(() => syncSlidersFromDOM(), 100);
    }
    init();
</script>
